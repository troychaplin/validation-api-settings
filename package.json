{
	"name": "@validation-api/settings",
	"version": "1.0.0",
	"description": "Admin settings page for the Validation API plugin",
	"private": true,
    "packageManager": "pnpm@10.33.0",
	"lint-staged": {
		"*.{css,scss}": [
			"stylelint --fix"
		],
		"*.js": [
			"wp-scripts format",
			"wp-scripts lint-js"
		],
		"*.php": [
			"composer run format"
		]
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@parcel/watcher",
			"core-js",
			"core-js-pure",
			"unrs-resolver"
		]
	},
	"files": [
		"[^.]*"
	],
	"scripts": {
		"build": "wp-scripts build",
		"start": "wp-scripts start",
		"test": "wp-scripts test-unit-js",
		"test:watch": "wp-scripts test-unit-js --watch",
		"format": "pnpm format:js && pnpm format:php && pnpm format:css",
		"format:js": "wp-scripts lint-js --fix",
		"format:php": "composer run format",
		"format:css": "stylelint \"**/*.scss\" --fix",
		"lint": "pnpm lint:js && pnpm lint:php && pnpm lint:css",
		"lint:js": "wp-scripts lint-js",
		"lint:php": "composer run lint",
		"lint:css": "stylelint \"**/*.scss\"",
		"clean": "rm -rf node_modules ; rm pnpm-lock.yaml ; pnpm install ; pnpm build",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip": "wp-scripts plugin-zip",
		"prepare": "husky"
	},
	"devDependencies": {
		"@wordpress/api-fetch": "^7.0.0",
		"@wordpress/components": "^29.0.0",
		"@wordpress/dataviews": "*",
		"@wordpress/element": "^6.0.0",
		"@wordpress/i18n": "^5.0.0",
		"@wordpress/scripts": "^31.0.0",
        "lint-staged": "^16.4.0",
        "eslint-config-prettier": "10.1.8",
		"husky": "9.1.7",
		"stylelint": "17.9.1",
		"stylelint-scss": "7.0.0"
	}
}
